# ─────────────────────────────────────────────────────────
# .env.example — salin ke .env lalu isi nilainya
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)
# Variabel di sini dibaca oleh config.yaml lewat sintaks ${NAMA_VAR}
# ─────────────────────────────────────────────────────────

# === Database (TimescaleDB / PostgreSQL) ===
# dipakai di config.yaml -> database.password & database.url
DB_PASSWORD=admin123

# === Claude / Anthropic API (LLM agent) ===
# dipakai saat blok config.yaml -> llm diaktifkan
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# === Telegram Alert ===
# dipakai di config.yaml -> alert.telegram
TELEGRAM_TOKEN=123456789:ABCdefGhIjKlmNoPQRstuVWxyz
TELEGRAM_CHAT_ID=-1001234567890
# ID admin yang boleh approve aksi high-risk
ADMIN_TELEGRAM_ID_1=111111111
ADMIN_TELEGRAM_ID_2=222222222
